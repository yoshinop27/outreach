# --- Database ---
DATABASE_URL="file:./dev.db"

# --- NextAuth ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-me"
NEXTAUTH_URL="http://localhost:3000"

# --- Microsoft Entra ID (Azure AD) app registration ---
# See README.md "Setting up Entra ID" for step-by-step instructions.
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
AZURE_AD_TENANT_ID=""

# --- Bootstrap admin ---
# The email of the first user, seeded as an active admin so someone can sign in
# and invite everyone else. Must match the email on the Entra ID account you'll
# sign in with (or the dev-login account, see below).
ADMIN_EMAIL="you@example.com"

# --- Dev-only login bypass ---
# When "true", the login page shows a "Dev Login" option that signs in as any
# seeded user by email, no Entra ID app registration required. Meant for local
# development only — never enable this in a deployed environment.
ENABLE_DEV_LOGIN="true"
