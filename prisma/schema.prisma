// Outreach Dashboard — MVP schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                      String    @id @default(cuid())
  googleSubjectId           String?   @unique
  email                   String    @unique
  displayName             String?
  role                    String    @default("user") // user | admin
  status                  String    @default("invited") // active | disabled | invited
  invitedByUserId         String?
  invitedBy               User?     @relation("Invites", fields: [invitedByUserId], references: [id])
  invitedUsers            User[]    @relation("Invites")
  googleAccountConnected Boolean   @default(false)
  googleAccessToken       String?
  googleRefreshToken      String?
  googleTokenExpiresAt    DateTime?
  googleScope             String?
  dailySendCapCurrent     Int       @default(20)
  apolloApiKey            String?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  lastLoginAt             DateTime?

  watchlistItems WatchlistItem[]
  templates      Template[]
}

model WatchlistItem {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName   String
  companyDomain String?
  targetTitles  String // JSON string[]
  location      String?
  seniority     String? // JSON string[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  contacts Contact[]
  @@index([userId])
}

model Contact {
  id                 String   @id @default(cuid())
  watchlistItemId    String
  watchlistItem      WatchlistItem @relation(fields: [watchlistItemId], references: [id], onDelete: Cascade)
  fullName           String
  title              String?
  companyName        String
  linkedinUrl        String?
  email              String?
  emailStatus        String   @default("not_found") // verified | guessed | not_found
  source             String   @default("apollo")
  discoveredAt       DateTime @default(now())
  status             String   @default("discovered")
  // discovered | sent | booked | ignored
  lastStatusChangeAt DateTime @default(now())

  outreachEvents OutreachEvent[]
  coffeeChats    CoffeeChat[]

  @@index([watchlistItemId])
}

model Template {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel   String // email | linkedin
  name      String
  subject   String?
  body      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  outreachEvents OutreachEvent[]
  
  @@index([userId])
}

model OutreachEvent {
  id                      String    @id @default(cuid())
  contactId               String
  contact                 Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  templateId              String?
  template                Template? @relation(fields: [templateId], references: [id])
  channel                 String // email | linkedin
  sentAt                  DateTime?
  openedAt                DateTime?
  repliedAt               DateTime?
  bounced                 Boolean   @default(false)
  manualActionCompletedAt DateTime?
  createdAt               DateTime  @default(now())

  @@index([contactId])
}

model CoffeeChat {
  id              String   @id @default(cuid())
  contactId       String
  contact         Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  scheduledAt     DateTime
  durationMinutes Int      @default(30)
  calendarEventId String?
  notes           String?
  outcome         String? // completed | no_show | rescheduled | cancelled
  createdAt       DateTime @default(now())

  @@index([contactId])
}
